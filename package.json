{
  "name": "mini-food",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*",
    "frontend/*"
  ],
  "scripts": {
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:prune": "docker compose down -v --remove-orphans",
    "test": "bun test",
    "format": "prettier --write \"**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "bun-types": "latest",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "pg": "^8.21.0",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prisma": "^7.8.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  },
  "dependencies": {
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-pg": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1"
  }
}