PORT=4003
# host "postgres", não "localhost" — é o nome do serviço na rede Docker
DATABASE_URL=postgresql://admin:admin@postgres:5432/delivery
RABBITMQ_URL=amqp://admin:admin@rabbitmq:5672

# ISSUER usa localhost: precisa bater com o "iss" DENTRO do token,
# e o token foi emitido para o browser, que acessa via localhost:8080
KEYCLOAK_ISSUER=http://localhost:8080/realms/mini-food
# JWKS usa o host interno: quem busca as chaves é o SERVIÇO, de dentro do Docker
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/mini-food/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=mini-food-client